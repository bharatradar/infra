#!/bin/bash
# BharatRadar Feeder Installer v5.4.0
#
# Standalone one-liner for setting up a BharatRadar ADS-B/MLAT feeder.
# No dependencies on bharatradar-install — works on any fresh Pi.
#
# Usage:
#   curl -Ls https://raw.githubusercontent.com/bharatradar/infra/main/scripts/bharatradar-feeder | sudo bash

set -euo pipefail

VERSION="5.7.0"
FEEDER_DOMAIN="feed.bharatradar.com"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }
log_step()    { echo -e "\n${CYAN}>>> $1${NC}"; }

print_banner() {
    echo ""
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}        BharatRadar Feeder Installer v${VERSION}${NC}"
    echo -e "${CYAN}        ADS-B / MLAT Receiver Setup${NC}"
    echo -e "${CYAN}================================================================${NC}"
    echo ""
}

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        log_error "This script must be run as root. Use: sudo bash"
        exit 1
    fi
}

check_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_ID="$ID"
    else
        log_error "Cannot detect OS"
        exit 1
    fi
    case "$OS_ID" in
        debian|ubuntu|raspbian)
            log_info "OS: $(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2)"
            ;;
        *)
            log_error "Unsupported OS: $OS_ID. Supported: Debian, Ubuntu, Raspberry Pi OS"
            exit 1
            ;;
    esac
}

detect_sdr_devices() {
    log_step "Detecting SDR Devices"

    if ! command -v lsusb &>/dev/null; then
        log_warn "lsusb not available, cannot auto-detect SDR"
        SDR_TYPE="none"
        return
    fi

    local lsusb_output
    lsusb_output=$(lsusb 2>/dev/null || echo "")

    if [ -z "$lsusb_output" ]; then
        log_warn "No USB devices found"
        SDR_TYPE="none"
        return
    fi

    local devices=()
    local ids=()
    local serials=()
    local buses=()
    local readsb_flags=()
    local count=0

    # RTL-SDR (RTL2832U) — multiple vendor IDs
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            local bus=$(echo "$line" | awk '{print $2}')
            local serial=""
            # Try to get serial via rtl_test later
            count=$((count + 1))
            devices+=("RTL-SDR ${line#*ID }")
            ids+=("$line")
            buses+=("$bus")
            readsb_flags+=("rtlsdr")
            serials+=("")
        fi
    done < <(echo "$lsusb_output" | grep -i "0bda:2832\|0bda:2838\|0bda:2830")

    # Airspy (Mini, R2, HF+)
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            local bus=$(echo "$line" | awk '{print $2}')
            local product_info=$(echo "$line" | awk -F'  ' '{print $NF}')
            local flag="airspy"
            if echo "$product_info" | grep -qi "hf"; then
                flag="airspyhf"
            fi
            devices+=("Airspy ${line#*ID }")
            ids+=("$line")
            buses+=("$bus")
            readsb_flags+=("$flag")
            serials+=("")
            count=$((count + 1))
        fi
    done < <(echo "$lsusb_output" | grep -i "1d50:60a1")

    # HackRF One
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            local bus=$(echo "$line" | awk '{print $2}')
            devices+=("HackRF One ${line#*ID }")
            ids+=("$line")
            buses+=("$bus")
            readsb_flags+=("hackrf")
            serials+=("")
            count=$((count + 1))
        fi
    done < <(echo "$lsusb_output" | grep -i "1d50:6089")

    if [ "$count" -eq 0 ]; then
        echo ""
        log_warn "No SDR device detected via USB"
        SDR_TYPE="none"
        return
    fi

    echo ""
    echo "  Found $count SDR device(s):"
    echo ""
    for i in "${!devices[@]}"; do
        echo "    $((i + 1))) ${devices[$i]}"
    done
    echo ""

    if [ "$count" -eq 1 ]; then
        log_info "Auto-selecting device 1"
        DETECTED_INDEX=0
    else
        local choice=""
        while true; do
            read -rp "  Select device [1-$count]: " choice < /dev/tty
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$count" ]; then
                DETECTED_INDEX=$((choice - 1))
                break
            fi
            echo "  Invalid selection. Please enter a number between 1 and $count."
        done
    fi

    SDR_DEVICE="${devices[$DETECTED_INDEX]}"
    SDR_READSB_FLAG="${readsb_flags[$DETECTED_INDEX]}"
    SDR_TYPE="sdr"

    # Try to get serial for RTL-SDR
    if [ "$SDR_READSB_FLAG" = "rtlsdr" ] && command -v rtl_test &>/dev/null; then
        local serial_info
        serial_info=$(rtl_test -t 2>&1 | grep "Found" | head -1 || true)
        if echo "$serial_info" | grep -q "Serial:"; then
            SDR_SERIAL=$(echo "$serial_info" | grep -oP 'Serial:\s*\K[0-9]+')
            log_info "Serial: $SDR_SERIAL"
        fi
    fi

    log_success "Selected: $SDR_DEVICE"
}

detect_existing_software() {
    log_step "Checking Existing Software"

    EXISTING_READSB=false
    EXISTING_TAR1090=false
    EXISTING_MLAT=false

    if command -v readsb &>/dev/null; then
        EXISTING_READSB=true
        local ver=$(readsb --version 2>/dev/null | head -1 || echo "installed")
        log_info "readsb found: $ver"
    elif dpkg -l readsb 2>/dev/null | grep -q "^ii"; then
        EXISTING_READSB=true
        log_info "readsb found (via dpkg)"
    fi

    if systemctl is-active tar1090 2>/dev/null || dpkg -l tar1090 2>/dev/null | grep -q "^ii"; then
        EXISTING_TAR1090=true
        log_info "tar1090 found"
    elif dpkg -l lighttpd 2>/dev/null | grep -q "^ii" && [ -d /usr/share/tar1090 ]; then
        EXISTING_TAR1090=true
        log_info "tar1090 found (via lighttpd)"
    fi

    if command -v mlat-client &>/dev/null; then
        EXISTING_MLAT=true
        local ver=$(mlat-client --version 2>/dev/null | head -1 || echo "installed")
        log_info "mlat-client found: $ver"
    fi

    if [ "$EXISTING_READSB" = false ] && [ "$EXISTING_TAR1090" = false ] && [ "$EXISTING_MLAT" = false ]; then
        log_info "No existing ADS-B software detected — fresh install"
    fi
}

prompt_existing_mode() {
    if [ "$EXISTING_READSB" = true ] || [ "$EXISTING_TAR1090" = true ]; then
        echo ""
        echo "  Existing ADS-B software detected on this system."
        echo "  What would you like to do?"
        echo ""
        echo "  1) Add BharatRadar feed to existing readsb (recommended)"
        echo "  2) Install fresh readsb alongside existing setup"
        echo "  3) Skip readsb, only install feeder bridge + MLAT"
        echo ""

        local choice=""
        while true; do
            read -rp "  Select [1-3]: " choice < /dev/tty
            case "$choice" in
                1) INSTALL_MODE="reconfigure"; break ;;
                2) INSTALL_MODE="fresh"; break ;;
                3) INSTALL_MODE="feeder-only"; break ;;
                *) echo "  Invalid selection. Please enter 1, 2, or 3." ;;
            esac
        done
    else
        INSTALL_MODE="fresh"
    fi
}

collect_config() {
    log_step "Feeder Configuration"

    echo ""
    echo "  Server: ${FEEDER_DOMAIN}"
    echo ""

    # Try to auto-detect location from public IP
    local detected_lat=""
    local detected_lon=""
    if command -v curl &>/dev/null; then
        local geo
        geo=$(curl -s --max-time 5 "http://ip-api.com/json" 2>/dev/null || echo "{}")
        detected_lat=$(echo "$geo" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('lat',''))" 2>/dev/null || true)
        detected_lon=$(echo "$geo" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('lon',''))" 2>/dev/null || true)
        if [ -n "$detected_lat" ] && [ -n "$detected_lon" ]; then
            log_info "Detected location from IP: $detected_lat, $detected_lon"
        fi
    fi

    local lat_default="${detected_lat:-18.480718}"
    local lon_default="${detected_lon:-73.898235}"

    echo ""
    read -rp "  Receiver latitude [$lat_default]: " READSB_LAT < /dev/tty
    READSB_LAT="${READSB_LAT:-$lat_default}"

    read -rp "  Receiver longitude [$lon_default]: " READSB_LON < /dev/tty
    READSB_LON="${READSB_LON:-$lon_default}"

    read -rp "  Antenna altitude in meters [10]: " FEEDER_ALT_M < /dev/tty
    FEEDER_ALT_M="${FEEDER_ALT_M:-10}"

    # UUID
    if [ -f /etc/bharat-radar-id ]; then
        local existing_uuid
        existing_uuid=$(cat /etc/bharat-radar-id 2>/dev/null | tr -d '[:space:]')
        if [ -n "$existing_uuid" ]; then
            log_info "Existing UUID found: ${existing_uuid}"
            local reuse="y"
            read -rp "  Reuse existing UUID? [Y/n]: " reuse < /dev/tty
            reuse=${reuse:-y}
            if [[ "$reuse" =~ ^[Yy]$ ]]; then
                FEEDER_UUID="$existing_uuid"
            fi
        fi
    fi

    if [ -z "${FEEDER_UUID:-}" ]; then
        FEEDER_UUID="BR-$(openssl rand -hex 9)"
        log_info "Generated UUID: ${FEEDER_UUID}"
    fi

    local name_default="BR-${FEEDER_UUID:3:6}"
    read -rp "  Feeder name (shows on MLAT map) [$name_default]: " FEEDER_NAME < /dev/tty
    FEEDER_NAME="${FEEDER_NAME:-$name_default}"

    # MLAT privacy
    echo ""
    local show_mlat="y"
    read -rp "  Show feeder on public MLAT map? [Y/n]: " show_mlat < /dev/tty
    show_mlat=${show_mlat:-y}
    if [[ "$show_mlat" =~ ^[Yy]$ ]]; then
        MLAT_PRIVACY=""
    else
        MLAT_PRIVACY="--privacy"
    fi

    echo ""
    log_step "Configuration Summary"
    echo -e "  Server:      ${CYAN}${FEEDER_DOMAIN}${NC}"
    echo -e "  Lat/Lon:     ${CYAN}${READSB_LAT}, ${READSB_LON}${NC}"
    echo -e "  Altitude:    ${CYAN}${FEEDER_ALT_M}m${NC}"
    echo -e "  UUID:        ${CYAN}${FEEDER_UUID}${NC}"
    echo -e "  Name:        ${CYAN}${FEEDER_NAME}${NC}"
    if [ "${SDR_TYPE:-none}" = "sdr" ]; then
        echo -e "  SDR Device:  ${CYAN}${SDR_DEVICE}${NC}"
    fi
    echo -e "  Install Mode: ${CYAN}${INSTALL_MODE}${NC}"
    if [ -n "$MLAT_PRIVACY" ]; then
        echo -e "  MLAT Map:    ${CYAN}hidden (privacy)${NC}"
    else
        echo -e "  MLAT Map:    ${CYAN}visible${NC}"
    fi
    echo ""

    local confirm="y"
    read -rp "  Proceed with installation? [Y/n]: " confirm < /dev/tty
    confirm=${confirm:-y}
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        log_info "Installation cancelled."
        exit 0
    fi
}

configure_cleanup() {
    log_step "Disk Cleanup Configuration"

    echo ""
    echo "  Automatic disk cleanup prevents disk-full issues."
    echo "  Runs daily via systemd timer, cleans by age OR disk size (whichever comes first)."
    echo ""

    read -rp "  Keep files for [7] days: " cleanup_days < /dev/tty
    CLEANUP_DAYS="${cleanup_days:-7}"

    read -rp "  Force cleanup if disk exceeds [80]%: " cleanup_pct < /dev/tty
    CLEANUP_SIZE_PCT="${cleanup_pct:-80}"

    log_info "Cleanup: ${CLEANUP_DAYS} days retention, ${CLEANUP_SIZE_PCT}% disk threshold"
}

install_packages() {
    log_step "Installing Base Packages"

    apt-get update -qq

    case "$OS_ID" in
        debian|ubuntu|raspbian)
            apt-get install -y -qq git build-essential debhelper pkg-config \
                python3 python3-requests socat libusb-1.0-0-dev 2>&1 | tail -1
            ;;
    esac

    log_success "Base packages installed"
}

install_rtlsdr() {
    if [ "${SDR_READSB_FLAG:-}" != "rtlsdr" ]; then
        return
    fi

    log_step "Installing rtl-sdr Library"

    # Check if already installed
    if ldconfig -p 2>/dev/null | grep -q librtlsdr; then
        log_info "rtl-sdr library already installed"
        return
    fi

    apt-get install -y -qq librtlsdr-dev rtl-sdr 2>&1 | tail -1

    # Blacklist conflicting kernel driver
    if [ -f /etc/modprobe.d/blacklist-rtl2832.conf ]; then
        log_info "Kernel driver already blacklisted"
    else
        cat > /etc/modprobe.d/blacklist-rtl2832.conf <<'EOF'
# Blacklist RTL2832 kernel driver — conflicts with rtl-sdr userspace
blacklist dvb_usb_rtl28xxu
blacklist rtl2832
blacklist rtl2830
EOF
        log_info "Blacklisted conflicting kernel drivers"
    fi

    # Unload if loaded
    rmmod dvb_usb_rtl28xxu 2>/dev/null || true
    rmmod rtl2832 2>/dev/null || true

    log_success "rtl-sdr installed"
}

install_readsb() {
    if [ "$INSTALL_MODE" = "feeder-only" ]; then
        log_step "Skipping readsb install (feeder-only mode)"
        return
    fi

    if command -v readsb &>/dev/null; then
        log_info "readsb already installed: $(readsb --version 2>/dev/null | head -1 || echo 'unknown')"
        return
    fi

    log_step "Installing readsb"

    local tmpdir
    tmpdir=$(mktemp -d)

    log_info "Cloning wiedehopf/readsb..."
    git clone --depth 1 https://github.com/wiedehopf/readsb.git "$tmpdir/readsb" 2>&1 | tail -1
    cd "$tmpdir/readsb"

    log_info "Building readsb (device: ${SDR_READSB_FLAG:-rtlsdr})..."
    local bladerf_opt="BLADERF=no"
    if [ "${SDR_READSB_FLAG:-}" = "hackrf" ]; then
        bladerf_opt="BLADERF=no"
    fi

    make -j"$(nproc)" $bladerf_opt 2>&1 | tail -5
    make install 2>&1 | tail -3

    cd /
    rm -rf "$tmpdir"

    log_success "readsb installed"
}

install_mlat_client() {
    if command -v mlat-client &>/dev/null; then
        log_info "mlat-client already installed: $(mlat-client --version 2>/dev/null | head -1 || echo 'unknown')"
        return
    fi

    log_step "Installing mlat-client"

    local tmpdir
    tmpdir=$(mktemp -d)

    log_info "Cloning wiedehopf/mlat-client..."
    git clone --depth 1 https://github.com/wiedehopf/mlat-client.git "$tmpdir/mlat-client" 2>&1 | tail -1
    cd "$tmpdir/mlat-client"

    make -j"$(nproc)" 2>&1 | tail -5
    cp mlat-client /usr/local/bin/mlat-client
    chmod +x /usr/local/bin/mlat-client

    cd /
    rm -rf "$tmpdir"

    log_success "mlat-client installed"
}

configure_readsb() {
    if [ "$INSTALL_MODE" = "feeder-only" ]; then
        return
    fi

    log_step "Configuring readsb"

    echo "$FEEDER_UUID" > /etc/bharat-radar-id
    chmod 644 /etc/bharat-radar-id

    local serial="${SDR_SERIAL:-0}"
    local device_flag="${SDR_READSB_FLAG:-rtlsdr}"

    # Map our detection to readsb's --device-type
    local device_type="$device_flag"
    case "$device_flag" in
        rtlsdr) device_type="rtlsdr" ;;
        airspy|airspyhf) device_type="$device_flag" ;;
        hackrf) device_type="hackrf" ;;
        *) device_type="rtlsdr" ;;
    esac

    cat > /etc/default/readsb <<EOF
# BharatRadar readsb configuration
# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
# Version: $VERSION

RECEIVER_OPTIONS="--device ${serial} --device-type ${device_type} --gain auto --ppm 0 --dcfilter --enable-biastee --uuid-file /etc/bharat-radar-id --preamble-threshold 58"
DECODER_OPTIONS="--lat ${READSB_LAT} --lon ${READSB_LON} --max-range 450 --fix"
NET_OPTIONS="--net --net-ingest --net-receiver-id --net-ri-port 30001 --net-ro-port 30002 --net-sbs-port 30003 --net-bi-port 30004,30104,31008,30105 --net-bo-port 30005 --net-beast-reduce-interval 0.5"
JSON_OPTIONS="--json-location-accuracy 2"
ADAPTIVE_DYNAMIC_RANGE=yes
EOF

    log_success "readsb configured"
}

add_bharatradar_to_existing_readsb() {
    if [ "$INSTALL_MODE" != "reconfigure" ]; then
        return
    fi

    log_step "Adding BharatRadar Feed to Existing readsb"

    # Check if readsb config exists
    if [ -f /etc/default/readsb ]; then
        local config
        config=$(cat /etc/default/readsb)

        # Add feeder connector if not already present
        if ! echo "$config" | grep -q "net-connector.*${FEEDER_DOMAIN}"; then
            # Append feeder connector to NET_OPTIONS
            if echo "$config" | grep -q "^NET_OPTIONS="; then
                local old_net
                old_net=$(grep "^NET_OPTIONS=" /etc/default/readsb)
                # Remove trailing quote and add connector
                local new_net="${old_net%\"}"
                new_net="${new_net} --net-connector ${FEEDER_DOMAIN},30004,beast_reduce_plus_out\""
                sed -i "s|^NET_OPTIONS=.*|${new_net}|" /etc/default/readsb
                log_info "Added feeder connector to existing readsb config"
            fi
        else
            log_info "BharatRadar feeder already in readsb config"
        fi
    fi

    # Set up bharatradar-specific feeder and mlat services
    # (reconfigure_existing_services below handles this)
}

create_feeder_service() {
    log_step "Creating bharatradar-feeder Service"

    if [ "$INSTALL_MODE" = "feeder-only" ]; then
        # In feeder-only mode, readsb is external — we still need a beast bridge
        cat > /etc/systemd/system/bharatradar-feeder.service <<EOF
[Unit]
Description=BharatRadar Beast Feeder Bridge
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/usr/bin/readsb --net-only --uuid-file /etc/bharat-radar-id \\
  --net-connector 127.0.0.1,30005,beast_in \\
  --net-connector ${FEEDER_DOMAIN},30004,beast_reduce_plus_out
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    else
        cat > /etc/systemd/system/bharatradar-feeder.service <<EOF
[Unit]
Description=BharatRadar Beast Feeder Bridge
After=network.target bharatradar-readsb.service
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/usr/bin/readsb --net-only --uuid-file /etc/bharat-radar-id \\
  --net-connector 127.0.0.1,30005,beast_in \\
  --net-connector ${FEEDER_DOMAIN},30004,beast_reduce_plus_out
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    fi

    systemctl daemon-reload
    systemctl enable bharatradar-feeder

    log_success "bharatradar-feeder service created"
}

create_mlat_service() {
    log_step "Creating bharatradar-mlat Service"

    cat > /etc/systemd/system/bharatradar-mlat.service <<EOF
[Unit]
Description=BharatRadar MLAT Client
After=network.target bharatradar-feeder.service

[Service]
Type=simple
ExecStart=/usr/local/bin/mlat-client \\
  --input-type beast \\
  --input-connect 127.0.0.1:30005 \\
  --server ${FEEDER_DOMAIN}:31090 \\
  --user ${FEEDER_UUID} \\
  --lat ${READSB_LAT} \\
  --lon ${READSB_LON} \\
  --alt ${FEEDER_ALT_M} \\
  ${MLAT_PRIVACY} \\
  --results beast,connect,127.0.0.1:30105
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable bharatradar-mlat

    log_success "bharatradar-mlat service created"
}

create_readsb_service() {
    if [ "$INSTALL_MODE" = "feeder-only" ]; then
        return
    fi

    log_step "Creating bharatradar-readsb Service"

    cat > /etc/systemd/system/bharatradar-readsb.service <<EOF
[Unit]
Description=BharatRadar ADS-B Receiver (readsb)
After=network.target

[Service]
Type=simple
ExecStartPre=/bin/sleep 2
ExecStart=/usr/bin/readsb \$(cat /etc/default/readsb | grep -v "^#\|^$" | tr '\n' ' ')
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

    # Actually, let's use a simpler approach — parse the config file
    cat > /etc/systemd/system/bharatradar-readsb.service <<EOF
[Unit]
Description=BharatRadar ADS-B Receiver (readsb)
After=network.target

[Service]
Type=simple
EnvironmentFile=/etc/default/readsb
ExecStart=/bin/bash -c '/usr/bin/readsb \$${RECEIVER_OPTIONS} \$${DECODER_OPTIONS} \$${NET_OPTIONS} \$${JSON_OPTIONS} \$${ADAPTIVE_DYNAMIC_RANGE:+--adaptive-dynamic-range}'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable bharatradar-readsb

    log_success "bharatradar-readsb service created"
}

start_services() {
    log_step "Starting Services"

    # Stop old services if they exist
    systemctl stop readsb 2>/dev/null || true
    systemctl stop bharat-feeder 2>/dev/null || true
    systemctl stop bharat-mlat 2>/dev/null || true

    # Start our services
    if [ "$INSTALL_MODE" != "feeder-only" ]; then
        systemctl restart bharatradar-readsb 2>/dev/null || true
    fi

    sleep 2
    systemctl restart bharatradar-feeder
    systemctl restart bharatradar-mlat

    sleep 5

    echo ""
    if systemctl is-active --quiet bharatradar-feeder; then
        log_success "bharatradar-feeder is running"
    else
        log_error "bharatradar-feeder failed to start"
        journalctl -u bharatradar-feeder --since "30 seconds ago" --no-pager 2>/dev/null || true
    fi

    if systemctl is-active --quiet bharatradar-mlat; then
        log_success "bharatradar-mlat is running"
    else
        log_error "bharatradar-mlat failed to start"
        journalctl -u bharatradar-mlat --since "30 seconds ago" --no-pager 2>/dev/null || true
    fi

    if [ "$INSTALL_MODE" != "feeder-only" ] && systemctl is-active --quiet bharatradar-readsb; then
        log_success "bharatradar-readsb is running"
    fi
}

save_config() {
    log_step "Saving Configuration"

    mkdir -p /etc/bharatradar

    cat > /etc/bharatradar/config.env <<EOF
# BharatRadar Feeder Configuration
# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
# Version: ${VERSION}

ROLE=feeder
FEEDER_DOMAIN="${FEEDER_DOMAIN}"
READSB_LAT="${READSB_LAT}"
READSB_LON="${READSB_LON}"
FEEDER_ALT_M="${FEEDER_ALT_M}"
FEEDER_UUID="${FEEDER_UUID}"
FEEDER_NAME="${FEEDER_NAME}"
SDR_SERIAL="${SDR_SERIAL:-0}"
SDR_TYPE="${SDR_TYPE:-none}"
SDR_DEVICE="${SDR_DEVICE:-none}"
SDR_READSB_FLAG="${SDR_READSB_FLAG:-rtlsdr}"
MLAT_PRIVACY="${MLAT_PRIVACY:-}"
INSTALL_MODE="${INSTALL_MODE}"
EOF

    chmod 600 /etc/bharatradar/config.env
    log_success "Configuration saved to /etc/bharatradar/config.env"
}

install_cleanup() {
    log_step "Installing Disk Cleanup Utility"

    # Install the cleanup script
    local cleanup_script
    cleanup_script=$(mktemp)

    curl -sL "https://raw.githubusercontent.com/bharatradar/infra/main/scripts/bharatradar-cleanup" -o "$cleanup_script" 2>/dev/null || {
        log_warn "Cannot fetch cleanup script from GitHub, bundling inline"
        # Bundle the cleanup script inline if curl fails
        cat > "$cleanup_script" <<'CLEANUP_EOF'
CLEANUP_EOF
        cat /dev/stdin >> "$cleanup_script" 2>/dev/null || true
    }

    if [ -s "$cleanup_script" ]; then
        cp "$cleanup_script" /usr/local/bin/bharatradar-cleanup
        chmod +x /usr/local/bin/bharatradar-cleanup
    fi
    rm -f "$cleanup_script"

    # Write cleanup config
    cat > /etc/bharatradar/cleanup.conf <<EOF
# BharatRadar Disk Cleanup Configuration
# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

CLEANUP_DAYS=${CLEANUP_DAYS}
CLEANUP_SIZE_PCT=${CLEANUP_SIZE_PCT}
EOF

    chmod 644 /etc/bharatradar/cleanup.conf

    # Create systemd service
    cat > /etc/systemd/system/bharatradar-cleanup.service <<EOF
[Unit]
Description=BharatRadar Disk Cleanup
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/bharatradar-cleanup --run
Nice=19
IOSchedulingClass=idle
EOF

    # Create systemd timer (daily at 3am with random delay)
    cat > /etc/systemd/system/bharatradar-cleanup.timer <<EOF
[Unit]
Description=BharatRadar Daily Disk Cleanup

[Timer]
OnCalendar=*-*-* 03:00:00
RandomizedDelaySec=3600
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl daemon-reload
    systemctl enable bharatradar-cleanup.timer
    systemctl start bharatradar-cleanup.timer

    log_success "Cleanup utility installed (daily at 3am)"
    log_info "Retention: ${CLEANUP_DAYS} days, Threshold: ${CLEANUP_SIZE_PCT}%"
    log_info "Manual run: bharatradar-cleanup --run"
    log_info "Dry run: bharatradar-cleanup --dry-run"
}

post_install() {
    local local_ip
    local_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    local base_domain
    base_domain=$(echo "$FEEDER_DOMAIN" | sed 's/^feed\.//')

    echo ""
    echo -e "${GREEN}================================================================${NC}"
    echo -e "${GREEN}        Feeder Setup Complete!${NC}"
    echo -e "${GREEN}================================================================${NC}"
    echo ""
    echo -e "  ${CYAN}Feeder UUID:${NC}  ${FEEDER_UUID}"
    echo -e "  ${CYAN}Feeder Name:${NC}  ${FEEDER_NAME}"
    echo -e "  ${CYAN}Server:${NC}       ${FEEDER_DOMAIN}"
    echo ""
    echo -e "  ${CYAN}Your Map:${NC}     https://my.${base_domain}"
    echo -e "  ${CYAN}Public Map:${NC}   https://map.${base_domain}"
    echo -e "  ${CYAN}MLAT Map:${NC}     https://mlat.${base_domain}"
    if [ "$INSTALL_MODE" != "feeder-only" ]; then
        echo -e "  ${CYAN}Local Map:${NC}    http://${local_ip}:8080/"
    fi
    echo ""
    echo -e "  ${CYAN}Check status:${NC}"
    echo "    sudo systemctl status bharatradar-feeder"
    echo "    sudo systemctl status bharatradar-mlat"
    if [ "$INSTALL_MODE" != "feeder-only" ]; then
        echo "    sudo systemctl status bharatradar-readsb"
    fi
    echo ""
    echo -e "  ${CYAN}View logs:${NC}"
    echo "    sudo journalctl -u bharatradar-feeder -f"
    echo "    sudo journalctl -u bharatradar-mlat -f"
    echo ""
    echo -e "${GREEN}================================================================${NC}"
}

# Main
main() {
    check_root
    print_banner
    check_os
    detect_sdr_devices
    detect_existing_software
    prompt_existing_mode
    collect_config
    configure_cleanup
    install_packages
    install_rtlsdr
    install_readsb
    add_bharatradar_to_existing_readsb
    install_mlat_client
    configure_readsb
    create_readsb_service
    create_feeder_service
    create_mlat_service
    start_services
    save_config
    install_cleanup
    post_install

    log_success "Feeder installation complete!"
}

main "$@"
