#!/bin/bash
# BharatRadar Disk Cleanup Utility v5.7.0
#
# Standalone disk cleanup tool for feeder nodes.
# Runs automatically via systemd timer or manually.
#
# Usage:
#   bharatradar-cleanup --run        # Execute cleanup
#   bharatradar-cleanup --dry-run    # Preview what would be cleaned
#   bharatradar-cleanup --configure  # Interactive configuration
#   bharatradar-cleanup --install    # Install systemd timer + service
#
# Config: /etc/bharatradar/cleanup.conf

set -euo pipefail

VERSION="5.7.0"
CONFIG_FILE="/etc/bharatradar/cleanup.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }
log_step()    { echo -e "\n${CYAN}>>> $1${NC}"; }

# Defaults
CLEANUP_DAYS=7
CLEANUP_SIZE_PCT=80
DRY_RUN=false

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        . "$CONFIG_FILE"
    else
        log_warn "No config found at $CONFIG_FILE, using defaults"
        log_warn "  CLEANUP_DAYS=$CLEANUP_DAYS, CLEANUP_SIZE_PCT=$CLEANUP_SIZE_PCT"
    fi
}

get_disk_usage_pct() {
    df / | awk 'NR==2 {gsub(/%/,"",$5); print $5}'
}

should_cleanup() {
    local disk_pct
    disk_pct=$(get_disk_usage_pct)

    # Always run if disk exceeds threshold
    if [ "$disk_pct" -ge "$CLEANUP_SIZE_PCT" ]; then
        log_info "Disk at ${disk_pct}% (threshold: ${CLEANUP_SIZE_PCT}%) — cleanup required"
        return 0
    fi

    # Run on schedule (age-based)
    log_info "Disk at ${disk_pct}% — running scheduled age-based cleanup (${CLEANUP_DAYS} days)"
    return 0
}

cleanup_tmp() {
    log_step "Cleaning /tmp (files older than ${CLEANUP_DAYS} days)"

    local count
    count=$(find /tmp -type f -mtime +"$CLEANUP_DAYS" 2>/dev/null | wc -l)
    local size
    size=$(du -sh /tmp 2>/dev/null | awk '{print $1}')

    if [ "$DRY_RUN" = true ]; then
        log_info "Would clean $count files from /tmp (current size: $size)"
        find /tmp -type f -mtime +"$CLEANUP_DAYS" 2>/dev/null | head -20
        return
    fi

    find /tmp -type f -mtime +"$CLEANUP_DAYS" -delete 2>/dev/null || true
    log_success "Cleaned /tmp — $count files removed"
}

cleanup_apt_cache() {
    log_step "Cleaning apt cache"

    local before
    before=$(du -sm /var/cache/apt/archives/ 2>/dev/null | awk '{print $1}')

    if [ "$DRY_RUN" = true ]; then
        log_info "Would clean apt cache (current size: ${before}MB)"
        ls -lh /var/cache/apt/archives/*.deb 2>/dev/null | head -10
        return
    fi

    apt-get clean 2>/dev/null || true
    log_success "Cleaned apt cache — freed ${before}MB"
}

cleanup_apt_autoremove() {
    log_step "Removing orphaned packages"

    local count
    count=$(apt list --autoremove 2>/dev/null | grep -c "/" || true)
    count=${count:-0}

    if [ "$DRY_RUN" = true ]; then
        log_info "Would remove $count orphaned packages"
        apt list --autoremove 2>/dev/null | grep "/" | head -10
        return
    fi

    if [ "$count" -gt 0 ]; then
        apt-get autoremove --purge -y 2>/dev/null | tail -1
        log_success "Removed $count orphaned packages"
    else
        log_info "No orphaned packages to remove"
    fi
}

cleanup_old_kernels() {
    log_step "Checking old kernel packages"

    if [ "$DRY_RUN" = true ]; then
        log_info "Would check for old kernel packages (current kernel: $(uname -r))"
        dpkg --list "linux-image-*" 2>/dev/null | grep "^ii" || true
        return
    fi

    local current_kernel
    current_kernel=$(uname -r | sed 's/-.*//')
    local old_kernels
    old_kernels=$(dpkg --list "linux-image-*" 2>/dev/null | grep "^ii" | awk '{print $2}' | grep -v "$current_kernel" | head -5)

    if [ -n "$old_kernels" ]; then
        while IFS= read -r kernel; do
            apt-get remove --purge -y "$kernel" 2>/dev/null || true
            log_info "Removed kernel: $kernel"
        done <<< "$old_kernels"
        log_success "Old kernels cleaned"
    else
        log_info "No old kernels to remove"
    fi
}

cleanup_journals() {
    log_step "Cleaning journal logs"

    local before
    before=$(journalctl --disk-usage 2>/dev/null | awk '{print $3, $4}' || echo "unknown")

    if [ "$DRY_RUN" = true ]; then
        log_info "Would vacuum journals (current size: $before)"
        return
    fi

    journalctl --vacuum-time="${CLEANUP_DAYS}d" --vacuum-size=200M 2>/dev/null || true
    local after
    after=$(journalctl --disk-usage 2>/dev/null | awk '{print $3, $4}' || echo "unknown")
    log_success "Journals vacuumed — before: $before, after: $after"
}

cleanup_rotated_logs() {
    log_step "Cleaning rotated logs (files older than ${CLEANUP_DAYS} days)"

    local count
    count=$(find /var/log -name "*.gz" -mtime +"$CLEANUP_DAYS" 2>/dev/null | wc -l)
    local size
    size=$(du -sh /var/log 2>/dev/null | awk '{print $1}')

    if [ "$DRY_RUN" = true ]; then
        log_info "Would clean $count rotated log files from /var/log (current size: $size)"
        find /var/log -name "*.gz" -mtime +"$CLEANUP_DAYS" 2>/dev/null | head -10
        return
    fi

    find /var/log -name "*.gz" -mtime +"$CLEANUP_DAYS" -delete 2>/dev/null || true
    find /var/log -name "*.[0-9]" -mtime +"$CLEANUP_DAYS" -delete 2>/dev/null || true
    log_success "Cleaned rotated logs — $count files removed"
}

cleanup_readsb_data() {
    log_step "Checking readsb/tar1090 data directories"

    local dirs=("/run/readsb" "/usr/local/share/tar1090/globe" "/usr/local/share/tar1090/heatmap" "/usr/share/tar1090/globe" "/usr/share/tar1090/heatmap")

    for dir in "${dirs[@]}"; do
        if [ -d "$dir" ]; then
            local size
            size=$(du -sh "$dir" 2>/dev/null | awk '{print $1}')

            if [ "$DRY_RUN" = true ]; then
                log_info "Would check $dir (current size: $size)"
                continue
            fi

            # Clean old JSON/stat files older than CLEANUP_DAYS
            if [ "$CLEANUP_DAYS" -gt 0 ]; then
                find "$dir" -type f -name "*.json" -mtime +"$CLEANUP_DAYS" -delete 2>/dev/null || true
                find "$dir" -type f -name "*.csv" -mtime +"$CLEANUP_DAYS" -delete 2>/dev/null || true
            fi
        fi
    done

    log_success "readsb/tar1090 data checked"
}

run_cleanup() {
    log_step "BharatRadar Disk Cleanup v${VERSION}"
    echo -e "  Config: ${CYAN}${CONFIG_FILE}${NC}"
    echo -e "  Retention: ${CYAN}${CLEANUP_DAYS} days${NC}"
    echo -e "  Disk threshold: ${CYAN}${CLEANUP_SIZE_PCT}%${NC}"
    if [ "$DRY_RUN" = true ]; then
        echo -e "  Mode: ${YELLOW}DRY RUN${NC}"
    fi

    local disk_before
    disk_before=$(get_disk_usage_pct)
    echo -e "  Disk usage: ${CYAN}${disk_before}%${NC}"

    cleanup_tmp
    cleanup_apt_cache
    cleanup_apt_autoremove
    cleanup_old_kernels
    cleanup_journals
    cleanup_rotated_logs
    cleanup_readsb_data

    local disk_after
    disk_after=$(get_disk_usage_pct)

    echo ""
    echo -e "${GREEN}================================================================${NC}"
    echo -e "${GREEN}  Cleanup complete — disk: ${disk_before}% → ${disk_after}%${NC}"
    echo -e "${GREEN}================================================================${NC}"
}

configure_interactive() {
    if [ "$(id -u)" -ne 0 ]; then
        log_error "This command must be run as root"
        exit 1
    fi

    echo ""
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}  BharatRadar Cleanup Configuration${NC}"
    echo -e "${CYAN}================================================================${NC}"
    echo ""

    read -rp "  Cleanup retention days [7]: " days < /dev/tty
    CLEANUP_DAYS="${days:-7}"

    read -rp "  Force cleanup if disk exceeds [80]%: " pct < /dev/tty
    CLEANUP_SIZE_PCT="${pct:-80}"

    echo ""
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" <<EOF
# BharatRadar Disk Cleanup Configuration
# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

CLEANUP_DAYS=${CLEANUP_DAYS}
CLEANUP_SIZE_PCT=${CLEANUP_SIZE_PCT}
EOF

    chmod 644 "$CONFIG_FILE"
    log_success "Configuration saved to $CONFIG_FILE"
    echo ""
    echo "  CLEANUP_DAYS=$CLEANUP_DAYS"
    echo "  CLEANUP_SIZE_PCT=$CLEANUP_SIZE_PCT"
}

install_timer() {
    if [ "$(id -u)" -ne 0 ]; then
        log_error "This command must be run as root"
        exit 1
    fi

    log_step "Installing systemd timer for automatic cleanup"

    # Install script to /usr/local/bin
    cp "$0" /usr/local/bin/bharatradar-cleanup
    chmod +x /usr/local/bin/bharatradar-cleanup

    # Create cleanup config if not exists
    if [ ! -f "$CONFIG_FILE" ]; then
        mkdir -p "$(dirname "$CONFIG_FILE")"
        cat > "$CONFIG_FILE" <<EOF
# BharatRadar Disk Cleanup Configuration
# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

CLEANUP_DAYS=7
CLEANUP_SIZE_PCT=80
EOF
        log_info "Created default config at $CONFIG_FILE"
    fi

    # Create systemd service
    cat > /etc/systemd/system/bharatradar-cleanup.service <<EOF
[Unit]
Description=BharatRadar Disk Cleanup
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/bharatradar-cleanup --run
Nice=19
IOSchedulingClass=idle
EOF

    # Create systemd timer (daily at 3am)
    cat > /etc/systemd/system/bharatradar-cleanup.timer <<EOF
[Unit]
Description=BharatRadar Daily Disk Cleanup

[Timer]
OnCalendar=*-*-* 03:00:00
RandomizedDelaySec=3600
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl daemon-reload
    systemctl enable bharatradar-cleanup.timer
    systemctl start bharatradar-cleanup.timer

    log_success "Cleanup timer installed (runs daily at 3am)"
    log_info "Next run: $(systemctl list-timers bharatradar-cleanup.timer --no-pager | tail -1 | awk '{print $1, $2, $3}')"
    log_info "Manual run: bharatradar-cleanup --run"
    log_info "Dry run: bharatradar-cleanup --dry-run"
    log_info "Reconfigure: bharatradar-cleanup --configure"
}

show_help() {
    echo "BharatRadar Disk Cleanup Utility v${VERSION}"
    echo ""
    echo "Usage:"
    echo "  bharatradar-cleanup --run        Execute cleanup"
    echo "  bharatradar-cleanup --dry-run    Preview what would be cleaned"
    echo "  bharatradar-cleanup --configure  Interactive configuration wizard"
    echo "  bharatradar-cleanup --install    Install systemd timer + service"
    echo "  bharatradar-cleanup --help       Show this help"
    echo ""
    echo "Config: $CONFIG_FILE"
    echo ""
    echo "What it cleans:"
    echo "  /tmp                  Files older than CLEANUP_DAYS"
    echo "  /var/cache/apt/       Cached .deb packages"
    echo "  apt autoremove        Orphaned packages"
    echo "  old kernels           Keep current + 1"
    echo "  journal logs          Vacuum to CLEANUP_DAYS / 200MB"
    echo "  rotated logs          *.gz files older than CLEANUP_DAYS"
    echo "  readsb/tar1090 data   Old JSON/CSV files"
}

# Main
case "${1:---help}" in
    --run)
        load_config
        should_cleanup
        run_cleanup
        ;;
    --dry-run)
        load_config
        DRY_RUN=true
        run_cleanup
        ;;
    --configure)
        configure_interactive
        ;;
    --install)
        load_config
        install_timer
        ;;
    --help|-h)
        show_help
        ;;
    *)
        log_error "Unknown option: $1"
        show_help
        exit 1
        ;;
esac
