# BharatRadar Database Configuration
# Copy this file to database.env and fill in your actual credentials

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=192.168.200.15
POSTGRES_PORT=5432
POSTGRES_DB=flight_db
POSTGRES_USER=flight_db_user
POSTGRES_PASSWORD=  # TODO: Fill in your password

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=192.168.200.15
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# InfluxDB Configuration (Optional - leave empty to skip)
